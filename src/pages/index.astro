---
import Icon from '../components/Icon.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import CtaSection from '../components/CtaSection.astro';
import ResponsiveImage from '../components/ResponsiveImage.astro';
import { getImage } from 'astro:assets';
import { heroImages, projectImages } from '../data/images';
import { galleryFilters, homeGalleryItems, homeServices } from '../data/home';

const heroPreload = await getImage({
  src: heroImages.kitchen1,
  width: 1440,
  format: 'avif',
  quality: 88,
});

const serviceHoverUrls = Object.fromEntries(
  await Promise.all(
    homeServices.map(async (service) => {
      const optimized = await getImage({
        src: service.hoverImage,
        width: 900,
        format: 'webp',
        quality: 82,
      });
      return [service.href, optimized.src] as const;
    })
  )
);
---

<BaseLayout
  title="Interior Designers in Mysuru & Karnataka | Space Solutions"
  description="Space Solutions provides residential and commercial interior design, modular kitchens, and turnkey fitouts in Mysuru and Karnataka with reliable execution and quality finishing."
  activePage="home"
  headerScrolled={false}
>
  <link
    slot="head"
    rel="preload"
    as="image"
    href={heroPreload.src}
    type="image/avif"
    fetchpriority="high"
  />

  <!-- Hero -->
  <section class="hero">
    <div class="swiper hero-swiper">
      <div class="swiper-wrapper">
        <div class="swiper-slide">
          <div class="hero-slide-bg">
            <ResponsiveImage src={heroImages.kitchen1} alt="" preset="hero" />
          </div>
        </div>
        <div class="swiper-slide">
          <div class="hero-slide-bg">
            <ResponsiveImage src={heroImages.bedroom} alt="" preset="hero" />
          </div>
        </div>
        <div class="swiper-slide">
          <div class="hero-slide-bg">
            <ResponsiveImage src={heroImages.kitchen2} alt="" preset="hero" />
          </div>
        </div>
      </div>
    </div>

    <div class="hero-content">
      <div class="container hero-grid">
        <div class="hero-text fade-up">
          <p class="section-label">Welcome To Space Solutions</p>
          <h1>Interiors Designed to Work.<br>Built to Last.</h1>
          <p>Modular furniture and interior solutions backed by 15+ years of experience, 800+ completed projects, and in-house manufacturing.</p>
          <a href="/portfolio" class="btn btn-outline-white">View Portfolio</a>
        </div>
        <div class="video-btn-wrap fade-up">
          <button class="video-btn hero-video-btn" aria-label="Play video">
            <Icon name="play" />
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="about" id="about">
    <div class="container about-grid">
      <div class="about-image fade-up">
        <ResponsiveImage
          src={projectImages.modularKitchen}
          alt="Space Solutions interior project"
          preset="content"
        />
      </div>
      <div class="about-content fade-up">
        <p class="section-label">About Us</p>
        <h2 class="section-title">We Don't Just Design.<br>We Deliver Complete Interiors.</h2>
        <p>At Space Solutions, every project starts with a clear understanding of how your space needs to function. Since 2011, we've worked with homeowners, businesses, and institutions across Karnataka to create interiors that are practical, durable, and well-finished. What makes us different is simple — we handle everything. From design and material selection to manufacturing and installation, every step is managed by our team. That means better quality, controlled timelines, and no guesswork.</p>
        <a href="/about" class="btn btn-gold-filled">Know more</a>
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="services" id="services">
    <div class="container">
      <p class="section-label fade-up">Our Services</p>
      <h3 class="section-heading-lg fade-up">Interior Solutions for Every Requirement</h3>
      <p class="section-desc fade-up">Whether it's a home, office, or large-scale project, we design solutions that are built for real use.</p>

      <div class="services-grid">
        {homeServices.map((service) => (
          <div
            class="service-card fade-up"
            style={`--hover-bg: url(${serviceHoverUrls[service.href]})`}
          >
            <div class="service-card-inner">
              <div class="service-icon"><Icon name={service.icon} /></div>
              <h4>{service.title}</h4>
              <p>{service.description}</p>
              <a href={service.href} class="service-link">Know More <Icon name="arrow-right" /></a>
            </div>
          </div>
        ))}
      </div>

      <a href="/residential-interiors" class="btn btn-gold-filled fade-up">View All Services</a>
    </div>
  </section>

  <!-- Projects -->
  <section class="projects" id="portfolio">
    <div class="container">
      <div class="projects-header">
        <div class="fade-up">
          <h3 class="section-heading-lg">Latest Projects</h3>
          <p class="section-desc">From compact homes to large commercial spaces, we've handled projects of all sizes. Our focus remains the same — deliver what was promised, with quality that lasts.</p>
        </div>
        <a href="/portfolio" class="btn btn-gold-filled fade-up">View Our Portfolio</a>
        <span class="projects-watermark">Portfolio</span>
      </div>

      <div class="portfolio-filters fade-up">
        {galleryFilters.map((filter, index) => (
          <button class:list={[{ active: index === 0 }]} data-filter={filter.id}>
            {filter.label}
          </button>
        ))}
      </div>

      <div class="portfolio-grid">
        {homeGalleryItems.map((item) => (
          <div class="portfolio-item fade-up" data-category={item.category}>
            <a href={item.href}>
              <ResponsiveImage src={item.image} alt={item.title} preset="grid" />
              <div class="portfolio-overlay">
                <span>{item.label}</span>
                <h4>{item.title}</h4>
              </div>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Why Choose Us -->
  <section class="why-choose" id="why-us">
    <div class="container">
      <h3 class="section-heading-lg fade-up">Why Clients Choose Space Solutions</h3>

      <div class="why-grid">
        <div class="why-card fade-up">
          <div class="why-icon"><Icon name="award" /></div>
          <h3>Experience That Shows in Every Project</h3>
          <p class="why-desc">15+ years of hands-on industry experience.</p>
        </div>
        <div class="why-card fade-up">
          <div class="why-icon"><Icon name="industry" /></div>
          <h3>In-House Manufacturing Advantage</h3>
          <p class="why-desc">Full control over quality, materials, and timelines.</p>
        </div>
        <div class="why-card fade-up">
          <div class="why-icon"><Icon name="clock" /></div>
          <h3>Built for Long-Term Use</h3>
          <p class="why-desc">We use materials that are made to handle daily wear.</p>
        </div>
        <div class="why-card fade-up">
          <div class="why-icon"><Icon name="tags" /></div>
          <h3>Clear Pricing</h3>
          <p class="why-desc">No confusion. No hidden costs.</p>
        </div>
        <div class="why-card fade-up">
          <div class="why-icon"><Icon name="users" /></div>
          <h3>Skilled Team</h3>
          <p class="why-desc">30+ professionals focused on delivering precise work.</p>
        </div>
        <div class="why-card fade-up">
          <div class="why-icon"><Icon name="pencil-ruler" /></div>
          <h3>Custom Solutions</h3>
          <p class="why-desc">Every project is designed based on your space and requirement.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Process -->
  <section class="process" id="process">
    <div class="container">
      <p class="section-label fade-up">Our Work Process</p>
      <h2 class="section-title fade-up">A Clear Process. No Confusion.</h2>
      <p class="section-desc fade-up">We keep things simple so you always know what's happening at every stage.</p>

      <div class="process-steps">
        <div class="process-step fade-up">
          <span class="step-num">01</span>
          <h4>Share Your Requirement</h4>
          <p>Tell us your requirement in detail, including your space, preferences, and expectations, so we can guide you with the right approach and next steps.</p>
        </div>
        <div class="process-step fade-up">
          <span class="step-num">02</span>
          <h4>Design &amp; Project Planning</h4>
          <p>We finalize the design, prepare detailed plans, and align materials, timelines, and execution to ensure everything is clearly defined before work begins.</p>
        </div>
        <div class="process-step fade-up">
          <span class="step-num">03</span>
          <h4>Installation &amp; Final Setup</h4>
          <p>We complete the installation with care, review every detail, and ensure the space is fully ready, clean, and functional for immediate use.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="testimonials" id="testimonials">
    <div class="container testimonials-frame">
      <h3 class="section-heading-lg fade-up">Testimonials</h3>

      <div class="swiper testimonial-swiper">
        <div class="swiper-wrapper">
          <div class="swiper-slide">
            <div class="testimonial-card">
              <p>We are absolutely thrilled with the incredible work Space Solutions did for our entire new built home. From our very first meeting, the team put us at ease and truly listened to our vision. Karthik was top-notch — he understands requirements perfectly. I personally recommend Space Solutions to anyone without a moment's hesitation.</p>
              <div class="testimonial-author">
                <strong>Sunilkumar SM</strong>
                <span class="testimonial-quote"><Icon name="quote-right" /></span>
              </div>
            </div>
          </div>
          <div class="swiper-slide">
            <div class="testimonial-card">
              <p>We visited their showroom in Kalidasa Road by chance as we lived nearby. I was impressed by the display of various kitchen options and the materials used. Harshita and team were good in giving us the best design and a reasonable quote followed by the neat execution of the job.</p>
              <div class="testimonial-author">
                <strong>Aparna Prasannakumar</strong>
                <span class="testimonial-quote"><Icon name="quote-right" /></span>
              </div>
            </div>
          </div>
          <div class="swiper-slide">
            <div class="testimonial-card">
              <p>We had a great experience with this interior designer. They use high-quality materials, offer excellent designs, and their response time is always quick. The entire process was very well-organised, and the final outcome was clean, detailed, and beautifully finished.</p>
              <div class="testimonial-author">
                <strong>MBH Creation</strong>
                <span class="testimonial-quote"><Icon name="quote-right" /></span>
              </div>
            </div>
          </div>
          <div class="swiper-slide">
            <div class="testimonial-card">
              <p>Space Solution is an absolute game-changer in the world of modular furniture and home interior design. Their modular furniture options are not only stylish and modern but also remarkably functional, maximizing every inch of space in my home.</p>
              <div class="testimonial-author">
                <strong>Karthik Prasad M</strong>
                <span class="testimonial-quote"><Icon name="quote-right" /></span>
              </div>
            </div>
          </div>
          <div class="swiper-slide">
            <div class="testimonial-card">
              <p>We had a great experience with Space Solutions. The transformation is remarkable. One of the best kitchen designers. From the designing to the execution, everything was perfect as envisioned. We are absolutely in love with our new kitchen.</p>
              <div class="testimonial-author">
                <strong>Vilina Ramesh</strong>
                <span class="testimonial-quote"><Icon name="quote-right" /></span>
              </div>
            </div>
          </div>
          <div class="swiper-slide">
            <div class="testimonial-card">
              <p>Absolutely beautiful interior solutions. Well priced also. Anyone wanting to do interiors please have a look. Great quality and timely completion of work.</p>
              <div class="testimonial-author">
                <strong>Sumitha Uchil</strong>
                <span class="testimonial-quote"><Icon name="quote-right" /></span>
              </div>
            </div>
          </div>
        </div>
        <div class="testimonial-pagination"></div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CtaSection />
</BaseLayout>
