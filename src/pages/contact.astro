---
import Icon from '../components/Icon.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import { SITE } from '../data/site';
---

<BaseLayout
  title="Contact Us | Space Solutions"
  description="Contact Space Solutions for interior design in Mysuru and Karnataka. Call +91 63645 64563 or request a free quote."
  activePage="contact"
  headerScrolled={false}
>
  <PageHero
    breadcrumb={'<a href="/">Home</a> <span class="breadcrumb-sep">/</span> Contact Us'}
    title="Contact Us"
    description="Let's bring your ideas to life with thoughtful design and practical solutions."
  />

  <section class="page-content">
    <div class="container contact-grid">
      <div class="contact-info fade-up">
        <h2 class="section-title">Get in touch</h2>
        <p>Reach out to create a space that's both functional and beautiful. Our team is ready to help with design, cost, and timeline.</p>
        <ul class="contact-details">
          <li>
            <Icon name="phone" />
            <div>
              <a href="tel:+916364564563">+91 63645 64563</a><br>
              <a href="tel:+919845241484">+91 98452 41484</a>
            </div>
          </li>
          <li>
            <Icon name="envelope" />
            <a href="mailto:marketing@spacesolution.co.in">marketing@spacesolution.co.in</a>
          </li>
          <li>
            <Icon name="location-dot" />
            <span>90, Kalidasa Rd, opp. Muthoot Finance, 3rd A Block, Vani Vilas Mohalla, Mysuru, Karnataka 570002</span>
          </li>
        </ul>
      </div>

      <div class="contact-form-wrap fade-up">
        <h3>Contact Form</h3>
        <form id="contact-form">
          <div class="form-group">
            <label>Your Name <span class="required">*</span></label>
            <input type="text" name="name" required placeholder="Your Name">
          </div>
          <div class="form-group">
            <label>Phone/Mobile <span class="required">*</span></label>
            <div class="phone-input">
              <select class="country-code" name="country"><option value="+91">+91</option></select>
              <input type="tel" name="phone" required placeholder="Phone/Mobile">
            </div>
          </div>
          <div class="form-group">
            <label>Email <span class="required">*</span></label>
            <input type="email" name="email" required placeholder="Email">
          </div>
          <div class="form-group">
            <label>Location</label>
            <input type="text" name="location" placeholder="Location">
          </div>
          <div class="form-group">
            <label>What Are You Looking For?</label>
            <select name="service">
              <option value="">- Select -</option>
              <option>Residential Interiors</option>
              <option>Commercial Interiors</option>
              <option>Hospitality Interiors</option>
              <option>Institutional Interiors</option>
              <option>Turnkey Fitout Solutions</option>
            </select>
          </div>
          <button type="submit" class="btn btn-gold-filled">Submit</button>
          <p class="form-feedback" aria-live="polite"></p>
        </form>
      </div>
    </div>

    <div class="container contact-map fade-up">
      <iframe
        src={SITE.mapEmbedUrl}
        title="Space Solutions location on Google Maps"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
      />
    </div>
  </section>
</BaseLayout>
