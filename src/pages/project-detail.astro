---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ResponsiveImage from '../components/ResponsiveImage.astro';
import { heroImages, youtubeThumbs } from '../data/images';
---

<BaseLayout
  title="Project Detail | Space Solutions"
  description="View project details from Space Solutions — residential and commercial interior design in Karnataka."
  activePage="portfolio"
  headerScrolled={true}
>
  <PageHero
    breadcrumb={'<a href="/" style="color:inherit">Home</a> / <a href="/portfolio" style="color:inherit">Portfolio</a> / Project Detail'}
    title="Project Detail"
  />

  <section class="page-content">
    <div class="container">
      <div class="project-detail-hero fade-up">
        <ResponsiveImage
          src={heroImages.bedroom}
          alt="Residential interior project"
          preset="content"
        />
      </div>

      <div class="project-detail-grid">
        <div class="project-detail-main fade-up">
          <h2>Project Info</h2>
          <p>Far far away, behind the word mountains, far from the countries Vokalia and Consonantia, there live the blind texts.</p>

          <div class="project-video-section">
            <h3>Watch Video</h3>
            <div class="project-video-thumb video-card" data-youtube="bt9uVqRqT_c">
              <ResponsiveImage
                src={youtubeThumbs.bt9uVqRqT_c}
                alt="Project video"
                preset="thumbnail"
              />
              <div class="play-overlay"><i class="fas fa-play-circle"></i></div>
            </div>
          </div>

          <div class="project-description">
            <h3>Project Description</h3>
            <p>I feel calm and happy in this place, like beautiful spring mornings. Alone, but enjoying the existence here that feels designed for happiness like mine. Truly happy, lulled by the tranquil presence, that I forget about my talents. Right now, I am unable to do anything.</p>
            <ul class="feature-list">
              <li>Small river named Duden flows by their place</li>
              <li>The Big Oxmox advised her not to do so</li>
              <li>Question Marks and devious Semikoli</li>
            </ul>
          </div>

          <div class="project-share fade-up">
            <h3>Share to Social Media Now!</h3>
            <p>Elevate your voice and expand your reach by sharing engaging content across diverse social media networks.</p>
            <div class="share-links">
              <a href="https://www.facebook.com/sharer/sharer.php?u=https://spacesolution.in" target="_blank" rel="noopener" aria-label="Share on Facebook"><i class="fab fa-facebook-f"></i></a>
              <a href="https://www.instagram.com/spacesolutions.mys" target="_blank" rel="noopener" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
              <a href="https://wa.me/?text=Check%20out%20this%20project%20from%20Space%20Solutions" target="_blank" rel="noopener" aria-label="Share on WhatsApp"><i class="fab fa-whatsapp"></i></a>
            </div>
          </div>
        </div>

        <aside class="project-meta fade-up">
          <h3>Project Details</h3>
          <div class="project-meta-list">
            <div class="project-meta-item">
              <h6>Client</h6>
              <p>Claudia Alves</p>
            </div>
            <div class="project-meta-item">
              <h6>Location</h6>
              <p>Seminyak, Kuta</p>
            </div>
            <div class="project-meta-item">
              <h6>Project Year</h6>
              <p>2020</p>
            </div>
            <div class="project-meta-item">
              <h6>Price Value</h6>
              <p>$250,000</p>
            </div>
            <div class="project-meta-item">
              <h6>Surface Area</h6>
              <p>400,000 m²</p>
            </div>
            <div class="project-meta-item">
              <h6>Project Head</h6>
              <p>Maximus Holden</p>
            </div>
          </div>
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
