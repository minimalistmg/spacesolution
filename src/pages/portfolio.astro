---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import CtaSection from '../components/CtaSection.astro';
import { portfolioVideos } from '../data/portfolio';
---

<BaseLayout
  title="Portfolio | Space Solutions"
  description="Explore Space Solutions portfolio — residential, commercial, and institutional interior design projects across Karnataka."
  activePage="portfolio"
  headerScrolled={false}
>
  <PageHero
    breadcrumb={'<a href="/">Home</a> <span class="breadcrumb-sep">/</span> Portfolio'}
    title="Portfolio"
    description="Turning ideas into well-executed spaces. A selection of projects that reflect our approach to planning, execution, and finishing."
  />

  <section class="page-content">
    <div class="container">
      <p class="section-label fade-up">Our Work</p>
      <h2 class="section-title fade-up">Turning ideas into well-executed spaces.</h2>
      <p class="section-desc fade-up">
        Each project is designed to meet specific requirements while maintaining consistency in quality and usability.
      </p>

      <div class="portfolio-videos fade-up">
        {portfolioVideos.map((video) => (
          <div class="portfolio-video">
            <iframe
              src={`https://www.youtube.com/embed/${video.id}?controls=1&rel=0&playsinline=0`}
              title={video.title}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaSection />
</BaseLayout>
