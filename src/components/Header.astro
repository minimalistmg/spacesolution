---
import Icon from './Icon.astro';
export type NavPage = 'home' | 'about' | 'services' | 'portfolio' | 'contact';

import ResponsiveImage from './ResponsiveImage.astro';
import { logoImages } from '../data/images';

interface Props {
  activePage?: NavPage;
  scrolled?: boolean;
}

const { activePage = 'home', scrolled = false } = Astro.props;
---

<header class:list={['site-header', { scrolled }]}>
  <div class="container header-inner">
    <a href="/" class="logo">
      <ResponsiveImage src={logoImages.header} alt="Space Solutions" preset="logo" />
    </a>

    <ul class="main-nav">
      <li class:list={[{ active: activePage === 'home' }]}>
        <a href="/">Home</a>
      </li>
      <li class:list={[{ active: activePage === 'about' }]}>
        <a href="/about">About Us</a>
      </li>
      <li class:list={['has-submenu', { active: activePage === 'services' }]}>
        <a href="#">Services</a>
        <ul class="submenu">
          <li><a href="/residential-interiors">Residential Interiors</a></li>
          <li><a href="/commercial-interiors">Commercial Interiors</a></li>
          <li><a href="/institutional-interiors">Institutional Interiors</a></li>
          <li><a href="/turnkey-fitout">Turnkey Fitout Solutions</a></li>
        </ul>
      </li>
      <li class:list={[{ active: activePage === 'portfolio' }]}>
        <a href="/portfolio">Portfolio</a>
      </li>
      <li class:list={[{ active: activePage === 'contact' }]}>
        <a href="/contact">Contact Us</a>
      </li>
    </ul>

    <a href="#" class="btn btn-outline-white header-cta" data-open-modal="enquiry">Get Started</a>

    <button class="menu-toggle" aria-label="Open menu">
      <Icon name="bars" />
    </button>
  </div>
</header>
