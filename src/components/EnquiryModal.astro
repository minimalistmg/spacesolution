---
import Icon from './Icon.astro';
import EnquiryForm from './EnquiryForm.astro';

interface Props {
  defaultServices?: string[];
}

const { defaultServices = [] } = Astro.props;
---

<div class="modal-overlay" id="enquiry-modal">
  <div class="modal enquiry-modal">
    <div class="enquiry-modal-inner">
      <div class="enquiry-modal-head">
        <div class="enquiry-modal-head-copy">
          <h2>Enquiry Form</h2>
          <p class="enquiry-modal-desc">Share a few details and we will get back to you.</p>
        </div>
        <button class="modal-close" type="button" aria-label="Close"><Icon name="times" /></button>
      </div>
      <EnquiryForm formId="enquiry-form" dataSource="enquiry" defaultServices={defaultServices} />
    </div>
  </div>
</div>
