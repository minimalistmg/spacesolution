---
import ResponsiveImage from './ResponsiveImage.astro';
import { projectImages } from '../data/images';

interface Props {
  defaultService?: string;
}

const { defaultService } = Astro.props;
---

<div class="modal-overlay" id="enquiry-modal">
  <div class="modal">
    <ResponsiveImage
      src={projectImages.homeInterior3}
      alt=""
      preset="cover"
      class="modal-bg"
    />
    <button class="modal-close" aria-label="Close"><i class="fas fa-times"></i></button>
    <h2>Enquiry Form</h2>
    <form id="enquiry-form">
      <div class="form-group">
        <label>Your Name <span class="required">*</span></label>
        <input type="text" name="name" required placeholder="Your Name" />
      </div>
      <div class="form-group">
        <label>Phone/Mobile <span class="required">*</span></label>
        <div class="phone-input">
          <select class="country-code" name="country">
            <option value="+91">+91</option>
          </select>
          <input type="tel" name="phone" required placeholder="Phone/Mobile" />
        </div>
      </div>
      <div class="form-group">
        <label>Email <span class="required">*</span></label>
        <input type="email" name="email" required placeholder="Email" />
      </div>
      <div class="form-group">
        <label>Location</label>
        <input type="text" name="location" placeholder="Location" />
      </div>
      <div class="form-group">
        <label>What Are You Looking For?</label>
        <select name="service">
          <option value="">- Select -</option>
          <option selected={defaultService === 'Residential Interiors'}>Residential Interiors</option>
          <option selected={defaultService === 'Commercial Interiors'}>Commercial Interiors</option>
          <option selected={defaultService === 'Hospitality Interiors'}>Hospitality Interiors</option>
          <option selected={defaultService === 'Institutional Interiors'}>Institutional Interiors</option>
          <option selected={defaultService === 'Turnkey Fitout Solutions'}>Turnkey Fitout Solutions</option>
        </select>
      </div>
      <button type="submit" class="btn btn-gold">Submit</button>
      <p class="form-feedback" aria-live="polite"></p>
    </form>
  </div>
</div>
