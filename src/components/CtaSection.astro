---
import ResponsiveImage from './ResponsiveImage.astro';
import { heroImages } from '../data/images';
---

<section class="cta">
  <ResponsiveImage
    src={heroImages.bedroom}
    alt=""
    preset="cover"
    class="cta-bg"
  />
  <div class="container cta-grid">
    <div class="fade-up">
      <p class="section-label">Get Started</p>
      <h1>Have a Space to Design?<br />Let's Get It Done Right.</h1>
      <p>Speak with our team and get a clear plan for your interiors — design, cost, and timeline.</p>
    </div>
    <a href="#" class="btn btn-outline-white fade-up" data-open-modal="enquiry">Request a Quote</a>
  </div>
</section>
