---
import Icon from './Icon.astro';

const heroVideoSrc = '/images/videos/hero-showreel.mp4';
---
<div class="modal-overlay video-modal" id="video-modal">
  <div class="modal video-modal-panel">
    <div class="video-modal-body">
      <button class="video-modal-close" type="button" aria-label="Close video">
        <Icon name="times" />
      </button>

      <iframe
        class="video-modal-youtube"
        title="Project video"
        allow="autoplay; encrypted-media; picture-in-picture"
        allowfullscreen
      ></iframe>

      <div class="video-modal-native">
        <video class="video-modal-player" playsinline preload="none" loop>
          <source src={heroVideoSrc} type="video/mp4" />
        </video>
        <div class="video-modal-controls">
          <button class="video-ctrl-btn video-ctrl-play" type="button" aria-label="Play">
            <Icon name="play" class="icon-play" />
            <Icon name="pause" class="icon-pause" />
          </button>
          <input
            class="video-ctrl-progress"
            type="range"
            min="0"
            max="100"
            value="0"
            step="0.1"
            aria-label="Seek"
          />
          <span class="video-ctrl-time">0:00 / 0:00</span>
          <button class="video-ctrl-btn video-ctrl-mute" type="button" aria-label="Mute">
            <Icon name="volume-high" class="icon-volume" />
            <Icon name="volume-xmark" class="icon-muted" />
          </button>
          <button class="video-ctrl-btn video-ctrl-fullscreen" type="button" aria-label="Fullscreen">
            <Icon name="expand" />
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
