---
import type { ImageMetadata } from 'astro';
import ResponsiveImage from './ResponsiveImage.astro';
import { pageHeroImage } from '../data/images';

interface Props {
  breadcrumb: string;
  title: string;
  description?: string;
  image?: ImageMetadata;
}

const { breadcrumb, title, description, image = pageHeroImage } = Astro.props;
---

<section class="page-hero">
  <div class="page-hero-bg" aria-hidden="true">
    <ResponsiveImage src={image} alt="" preset="hero" />
  </div>
  <div class="page-hero-overlay" aria-hidden="true"></div>
  <div class="container page-hero-content">
    <nav class="breadcrumb" aria-label="Breadcrumb" set:html={breadcrumb} />
    <h1 class="page-hero-title">{title}</h1>
    {description && <p class="page-hero-desc">{description}</p>}
  </div>
</section>
