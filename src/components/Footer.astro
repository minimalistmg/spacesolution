---
import Icon from './Icon.astro';
import ResponsiveImage from './ResponsiveImage.astro';
import { logoImages } from '../data/images';
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="/">
        <ResponsiveImage src={logoImages.footer} alt="Space Solutions" preset="logo" />
      </a>
      <p>Space Solution creates beautiful, functional spaces with 15+ years of interior design expertise across Karnataka.</p>
      <div class="social-links">
        <a href="https://www.facebook.com/spacesolutio" target="_blank" rel="noopener" aria-label="Facebook"><Icon name="facebook" /></a>
        <a href="https://www.instagram.com/spacesolutions.mys" target="_blank" rel="noopener" aria-label="Instagram"><Icon name="instagram" /></a>
      </div>
    </div>
    <div class="footer-col">
      <h5>Quick Links</h5>
      <ul class="footer-links">
        <li><a href="/"><Icon name="angle-double-right" /> Home</a></li>
        <li><a href="/#studio"><Icon name="angle-double-right" /> Studio</a></li>
        <li><a href="/residential-interiors"><Icon name="angle-double-right" /> Services</a></li>
        <li><a href="/portfolio"><Icon name="angle-double-right" /> Projects</a></li>
        <li><a href="/design-library"><Icon name="angle-double-right" /> Design Library</a></li>
        <li><a href="/contact"><Icon name="angle-double-right" /> Enquire</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h5>Useful Links</h5>
      <ul class="footer-links">
        <li><a href="/privacy-policy"><Icon name="angle-double-right" /> Privacy Policy</a></li>
        <li><a href="#"><Icon name="angle-double-right" /> Terms Of Service</a></li>
        <li><a href="/faq"><Icon name="angle-double-right" /> FAQ</a></li>
      </ul>
    </div>
    <div class="footer-col">
      <h5>Get In Touch</h5>
      <ul class="footer-links">
        <li>
          <span class="footer-contact-item">
            <Icon name="location-dot" />
            90, Kalidasa Rd, opp. Muthoot Finance, 3rd A Block, Vani Vilas Mohalla, Mysuru, Karnataka 570002
          </span>
        </li>
        <li><a href="tel:+916364564563"><Icon name="phone" /> +91 63645 64563</a></li>
        <li><a href="tel:+919845241484"><Icon name="phone" /> +91 98452 41484</a></li>
        <li><a href="mailto:marketing@spacesolution.co.in"><Icon name="envelope" /> marketing@spacesolution.co.in</a></li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="container">
      <p>Copyright &copy; 2026 Space Solutions. All rights reserved.</p>
    </div>
  </div>
</footer>
